DRIVER=~fastapi+~websockets
# bot运行时监听的地址和端口
HOST=0.0.0.0
PORT=12035

# 与napcat加密通信时的握手密钥
ONEBOT_ACCESS_TOKEN=your-token

# 是否在启动时检查数据库连接，建议在生产环境中开启以避免运行时错误
ALEMBIC_STARTUP_CHECK=True

# 数据库实际地址，docker容器中建议使用绝对地址而不是相对地址
SQLALCHEMY_DATABASE_URL=sqlite+aiosqlite:////app/data/db.sqlite3

# 日志级别，建议在开发环境中使用DEBUG，在生产环境中使用INFO或更高级别以减少日志输出
LOG_LEVEL=INFO

# 超级管理员列表，格式为JSON数组，包含允许使用管理员命令的QQ号，例如：["12345678", "87654321"]
SUPERUSERS='["your-qq"]'

# 命令前缀列表，格式为JSON数组，包含触发命令的前缀，例如：["/", "!"]，如果不需要前缀可以设置为[""]，但不建议在生产环境中使用空前缀以避免误触发
COMMAND_START=[""]

# rsshub地址和
RSSHUB_HOST=your-rsshub-host
RSSHUB_HOST_BACK=["your-rsshub-host-back"]


# 机器翻译的key，trans模型名称需要根据实际使用的模型进行替换
API_KEY=your-deepseek-key
SECRET_KEY=your-deepseek-secret-key
MODEL_NAME=your-trans-model-name

# 发送和并转发消息时所使用时QQ号
SELF_ID=your-bot-qq

# 可用性监控配置
# 发送bot在线消息的目标群，int
TARGET_GROUPS=your-target-groups
# 可用性监控的URL，建议在生产环境中使用HTTPS地址以确保安全通信
UT_URL=your-ut-url
DETECT_URL=your-detect-url

# 更新时间间隔，单位为分钟，建议根据实际需求设置合理的值以平衡数据更新频率和系统负载
REFRESH_TIME=20

